/*=========================================
OCEAN PULSE
v1.0 FOUNDATION
=========================================*/

#ocean-pulse{

position:relative;

display:flex;

align-items:center;

height:52px;

width:100%;

padding:0 14px;

}

/*========================*/

.op-wrapper{

position:relative;

width:100%;

display:block;

padding-bottom:340px;

margin-bottom:-340px;

}

/*========================*/

.op-bar{

height:52px;

display:flex;

align-items:center;

gap:14px;

padding:0 18px;

border-radius:16px;

background:rgba(255,255,255,.03);

border:1px solid rgba(255,255,255,.05);

cursor:pointer;

transition:.35s;

position:relative;

z-index:1000;

}

.op-bar:hover{

background:rgba(255,255,255,.05);

border-color:rgba(0,213,255,.22);

}

/*========================*/

.op-icon{

font-size:24px;

display:flex;

align-items:center;

justify-content:center;

width:30px;

flex-shrink:0;

}

/*========================*/

.op-title{

flex:1;

font-size:16px;

font-weight:700;

color:#fff;

letter-spacing:.2px;

}

/*========================*/

.op-arrow{

width:18px;

height:18px;

display:flex;

align-items:center;

justify-content:center;

color:#74ddff;

animation:oceanArrow 2.2s infinite;

transition:.35s;

}

.op-bar:hover .op-arrow{

transform:rotate(180deg);

}

.op-arrow svg{

width:16px;

height:16px;

}

/*========================*/

.op-panel{

position:absolute;

top:64px;

left:50%;

transform:translateX(-50%) translateY(-12px);

width:620px;

pointer-events:none;

min-height:420px;

border-radius:28px;

background:
linear-gradient(
180deg,
rgba(9,24,40,.92),
rgba(5,18,30,.94)
);

backdrop-filter:blur(22px);

-webkit-backdrop-filter:blur(22px);

border:1px solid rgba(120,225,255,.18);

box-shadow:

0 35px 80px rgba(0,0,0,.45),

0 0 40px rgba(0,213,255,.08);

opacity:0;

visibility:hidden;

transition:

opacity .35s,

transform .35s;

overflow:hidden;

z-index:999;

}

/*========================*/

.op-wrapper:hover .op-panel{

opacity:1;

pointer-events:auto;

visibility:visible;

transform:translateX(-50%) translateY(0);

}

/*========================*/

@keyframes oceanArrow{

0%{

transform:translateY(0);

}

50%{

transform:translateY(4px);

}

100%{

transform:translateY(0);

}

}

/*=========================================
LUXURY PANEL
=========================================*/

.op-panel::before{

content:"";

position:absolute;

top:-10px;

left:50%;

margin-left:-10px;

width:20px;

height:20px;

background:rgba(9,24,40,.95);

border-left:1px solid rgba(120,225,255,.18);

border-top:1px solid rgba(120,225,255,.18);

transform:rotate(45deg);

}

.op-item{

display:flex;

align-items:center;

gap:18px;

padding:22px 24px;

border-bottom:1px solid rgba(255,255,255,.06);

transition:.35s;

cursor:pointer;

position:relative;

overflow:hidden;

}

.op-item:last-child{

border-bottom:none;

}

.op-item::before{

content:"";

position:absolute;

left:-100%;

top:0;

width:100%;

height:100%;

background:

linear-gradient(

90deg,

transparent,

rgba(0,213,255,.08),

transparent

);

transition:.55s;

}

.op-item:hover::before{

left:100%;

}

.op-item:hover{

background:rgba(255,255,255,.03);

transform:translateX(6px);

}

.op-item-icon{

font-size:34px;

width:56px;

display:flex;

justify-content:center;

align-items:center;

flex-shrink:0;

}

.op-item-text{

flex:1;

}

.op-item-text h4{

margin:0;

font-size:22px;

font-weight:700;

color:white;

}

.op-item-text p{

margin-top:6px;

font-size:15px;

color:rgba(255,255,255,.70);

}

.op-go{

width:44px;

height:44px;

border-radius:50%;

border:1px solid rgba(255,255,255,.10);

display:flex;

align-items:center;

justify-content:center;

font-size:22px;

color:#8de8ff;

transition:.35s;

}

.op-item:hover .op-go{

background:#00d5ff;

color:#00111d;

transform:translateX(4px);

}